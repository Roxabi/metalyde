{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "ignoreCommand": "[ \"$VERCEL_GIT_COMMIT_REF\" != \"main\" ] || npx turbo-ignore @repo/web",
  "installCommand": "bun install --ignore-scripts",
  "buildCommand": "turbo run build",
  "redirects": [
    {
      "source": "/docs/(.*)",
      "destination": "https://docs.metalyde.roxabi.dev/$1",
      "permanent": false
    },
    { "source": "/docs", "destination": "https://docs.metalyde.roxabi.dev", "permanent": false }
  ]
}
